<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>New Tab</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    body {
      background: #1a1a2e;
      color: #cdd6f4;
      font-family: system-ui, -apple-system, sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 28px;
      user-select: none;
    }
 
    #clock {
      font-size: 80px;
      font-weight: 200;
      letter-spacing: -3px;
      color: #cdd6f4;
      line-height: 1;
    }
 
    #date {
      font-size: 18px;
      color: #6c7086;
      margin-top: -16px;
      font-weight: 400;
    }
 
    #search-wrap {
      display: flex;
      align-items: center;
      background: #181825;
      border: 1px solid #313244;
      border-radius: 100px;
      padding: 13px 24px;
      width: 520px;
      gap: 13px;
      transition: border-color .15s, box-shadow .15s;
    }
    #search-wrap:focus-within {
      border-color: #89b4fa;
      box-shadow: 0 0 0 3px rgba(137,180,250,.15);
    }
 
    #search-wrap svg { flex-shrink: 0; color: #6c7086; }
 
    #q {
      flex: 1;
      background: none;
      border: none;
      outline: none;
      color: #cdd6f4;
      font-size: 17px;
      font-family: inherit;
    }
    #q::placeholder { color: #45475a; }
 
    .hint {
      font-size: 15px;
      color: #45475a;
      display: flex;
      align-items: center;
      gap: 7px;
    }
    kbd {
      background: #313244;
      border: 1px solid #45475a;
      border-radius: 5px;
      padding: 3px 9px;
      font-size: 14px;
      font-family: inherit;
      color: #bac2de;
    }
  </style>
</head>
<body>
 
  <div id="clock"></div>
  <div id="date"></div>
 
  <form id="search-wrap" onsubmit="doSearch(event)">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input id="q" type="text" placeholder="Search Google or type a URL" autofocus autocomplete="off">
  </form>
 
  <div class="hint">Press <kbd>Ctrl + 8</kbd> to open the Time Limiter panel</div>
 
  <script>
    // Clock
    function tick() {
      const d = new Date();
      const h = String(d.getHours()).padStart(2,'0');
      const m = String(d.getMinutes()).padStart(2,'0');
      document.getElementById('clock').textContent = h + ':' + m;
      const DAYS   = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      const MONTHS = ['January','February','March','April','May','June',
                      'July','August','September','October','November','December'];
      document.getElementById('date').textContent =
        DAYS[d.getDay()] + ', ' + MONTHS[d.getMonth()] + ' ' + d.getDate();
    }
    tick();
    setInterval(tick, 1000);
 
    // Search / URL handling
    function doSearch(e) {
      e.preventDefault();
      const v = document.getElementById('q').value.trim();
      if (!v) return;
      // Bare domain (e.g. "github.com") → navigate directly
      if (/^[\w-]+(\.[\w-]+)+$/.test(v)) { location.href = 'https://' + v; return; }
      // Full URL → navigate directly
      if (/^https?:\/\//.test(v)) { location.href = v; return; }
      // Everything else → Google search
      location.href = 'https://www.google.com/search?q=' + encodeURIComponent(v);
    }
  </script>
 
</body>
</html>
